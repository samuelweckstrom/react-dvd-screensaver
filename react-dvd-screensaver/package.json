{
  "name": "react-dvd-screensaver",
  "description": "DVD-era nostalgia in React. Zero dependencies, fully typed, SSR-safe, supports React 16 through 19.",
  "version": "0.1.2",
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "llms.txt"
  ],
  "types": "./dist/index.d.ts",
  "typings": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/samuelweckstrom/react-dvd-screensaver"
  },
  "author": "Samuel Weckström",
  "license": "MIT",
  "peerDependencies": {
    "react": "^16.3 || ^17.0 || ^18.0 || ^19.0"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup"
  },
  "keywords": [
    "react",
    "dvd",
    "dvd-screensaver",
    "screensaver",
    "bouncing",
    "bouncing-logo",
    "animation",
    "react-hook",
    "hook",
    "floating",
    "marquee",
    "nostalgia",
    "retro",
    "requestanimationframe",
    "typescript",
    "zero-dependencies"
  ],
  "devDependencies": {
    "@types/react": "^19.2.14"
  }
}
