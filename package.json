{
  "name": "monorepo",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "workspaces": [
    "demo",
    "react-dvd-screensaver"
  ],
  "scripts": {
    "dev:demo": "pnpm --filter demo run dev",
    "dev:package": "pnpm --filter react-dvd-screensaver run dev",
    "build:demo": "pnpm --filter demo run build",
    "build:package": "pnpm --filter react-dvd-screensaver run build",
    "test": "jest --passWithNoTests"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "unrs-resolver"]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.14",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}
